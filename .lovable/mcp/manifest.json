              "description": "Case-insensitive substring match on the resident name."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows to return (default 25)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_access_entries",
        "title": "List access entries",
        "description": "List recent visitor/access entries visible to the signed-in user (RLS-scoped). Optionally filter by apartment.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
