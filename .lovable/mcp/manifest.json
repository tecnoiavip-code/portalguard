        "inputSchema": {
          "type": "object",
          "properties": {
            "apartment": {
              "type": "string",
              "description": "Filter by apartment."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows (default 25)."
